# ┌────────────────────────────────────────────────────────────────────────────┐
# │  VERY NAS MEDIA SERVER - ENVIRONMENT CONFIGURATION                        │
# └────────────────────────────────────────────────────────────────────────────┘

# ─── SYSTEM ──────────────────────────────────────────────────────────────────
PUID=1000
PGID=1000
TZ=America/New_York

# ─── PATHS: CONFIGURATION ────────────────────────────────────────────────────
CONFIG_ROOT=/path/to/config

# ─── PATHS: MEDIA LIBRARIES ──────────────────────────────────────────────────
DOWNLOADS_ROOT=/path/to/downloads
MOVIES_ROOT=/path/to/movies
TV_ROOT=/path/to/TV_ROOT

# ─── PORTS: VPN TUNNELED SERVICES ────────────────────────────────────────────
QBITTORRENT_PORT=8080
QBITTORRENT_TORRENT_PORT=6881
SABNZBD_PORT=8081
PROWLARR_PORT=9696
RADARR_PORT=7878
SONARR_PORT=8989
READARR_PORT=8787

# ─── PORTS: MEDIA SERVERS ────────────────────────────────────────────────────
JELLYFIN_PORT=8096
JELLYSEERR_PORT=5055
PLEX_PORT=32400

# ─── CREDENTIALS: VPN ────────────────────────────────────────────────────────
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# ─── CREDENTIALS: SERVICES ───────────────────────────────────────────────────
PLEX_CLAIM=
CLOUDFLARED_TOKEN=

# ─── VAULTWARDEN ──────────────────────────────────────────────────────────────
# Domain must be https:// for attachments to work behind reverse proxy
VAULTWARDEN_DOMAIN=https://vault.pranavprem.com
# Set to true only for first account creation, then set back to false
VAULTWARDEN_SIGNUPS_ALLOWED=false
# Generate with: docker run --rm -it vaultwarden/server /vaultwarden hash
# Use Argon2id PHC string for security (or plain token for initial setup)
VAULTWARDEN_ADMIN_TOKEN=